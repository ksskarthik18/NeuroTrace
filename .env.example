# NeuroTrace Environment Variables
# Copy this file to .env and fill in your values

# LLM API Keys
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# LLM Settings
LLM_PROVIDER=groq
LLM_MODEL=llama3-70b-8192

# App Settings
APP_ENV=development
DEBUG=true
LOG_LEVEL=info

# Database
DATABASE_URL=sqlite+aiosqlite:///./neurotrace.db

# Sandbox Settings
SANDBOX_TIMEOUT=10
SANDBOX_MAX_MEMORY_MB=256
